# LLM API Keys
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
SILICONFLOW_API_KEY=sk-your-siliconflow-api-key

# LLM Configuration
CHAT_BASE_URL=https://api.deepseek.com
CHAT_MODEL=deepseek-v4-flash
EMBEDDING_BASE_URL=https://api.siliconflow.cn
EMBEDDING_MODEL=BAAI/bge-m3

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://rag_agent:rag_agent@localhost:5432/rag_agent
DATABASE_URL_SYNC=postgresql+psycopg2://rag_agent:rag_agent@localhost:5432/rag_agent

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=rag-agent
MINIO_SECURE=false

# Agent
MAX_LOOPS=5
SEMANTIC_CACHE_THRESHOLD=0.92
CACHE_TTL=3600

# Document
CHUNK_SIZE=800
CHUNK_OVERLAP=100

# Sandbox
SANDBOX_IMAGE=python:3.11-slim
SANDBOX_TIMEOUT=10

# LightRAG
LIGHTRAG_WORKING_DIR=./lightrag_data
LIGHTRAG_IMPORTANCE_LEVEL=L2

# App
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
